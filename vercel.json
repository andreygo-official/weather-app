{
  "version": 2,
  "functions": {
    "server/index.js": {
      "runtime": "@vercel/node"
    }
  },
  "routes": [
    { "src": "/api/weather", "dest": "/server/index.js" },
    { "src": "/api/weather/forecast", "dest": "/server/index.js" },
    { "src": "/api/news", "dest": "/server/index.js" },
    { "src": "/api/news/:id", "dest": "/server/index.js" }
  ]
}
